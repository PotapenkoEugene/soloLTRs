references/

# Local tool builds (Look4LTRs, soloLTRseeker clones)
tools/

# Pipeline generated output (collapsed consensus, bwa-mem2 index, result TSVs)
data/pipeline/

# Semi-synthetic benchmark: large/generated files
data/semisyn/genomes/
data/semisyn/annotations/
data/semisyn/extracted/
data/semisyn/samples/**/genome.fa
data/semisyn/samples/**/reads_*/
